# Copy to .env.local. All optional — lib/contracts.ts hardcodes Base-mainnet defaults.

# Deployed KittiLottery contract
NEXT_PUBLIC_LOTTERY_ADDRESS=

# USDC (or MockERC20 on testnet, 6 decimals)
NEXT_PUBLIC_TOKEN_ADDRESS=

# Default chain (8453 = Base mainnet, 84532 = Base Sepolia)
NEXT_PUBLIC_DEFAULT_CHAIN_ID=8453

# Optional — WalletConnect (MetaMask + Coinbase Wallet work without this)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
