# Copy to .env and fill in. NEVER commit .env.

# Deployer private key (0x-prefixed). This EOA only broadcasts the deploy and
# pays gas — it never holds ownership (see CONTRACT_OWNER), so a Safe signer key
# or any funded EOA works.
PRIVATE_KEY=

# RPC endpoints (public Base RPCs used if unset)
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Basescan API key for contract verification — https://basescan.org/myapikey
BASESCAN_API_KEY=

# Initial contract owner. Set to your Safe multisig so the contract is Safe-owned
# from tx #1 — no transferOwnership step. REQUIRED for mainnet (base). Defaults to
# deployer if unset (testnet/local convenience only).
CONTRACT_OWNER=

# Address that receives the 5% protocol fee. Can be the same Safe as CONTRACT_OWNER.
# REQUIRED for mainnet (base). Defaults to deployer if unset.
FEE_RECIPIENT=

# Pyth Entropy contract address (randomness source). This IS a fixed public chain
# constant. Base mainnet is hardcoded in scripts/deploy.js
# (0x6E7D74FA7d5c90FEF9F0512987605a6d546181Bb); only set this to override or for
# Base Sepolia — look it up at docs.pyth.network/entropy/contract-addresses.
ENTROPY_ADDRESS=
